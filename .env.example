# Obtén tu token en https://t.me/BotFather
BOT_TOKEN=your_telegram_bot_token_here

# Opcional: tu Telegram user ID para /admin
ADMIN_ID=

# Credenciales de https://my.telegram.org (para servidor local)
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# (Opcional) Ruta al archivo cookies.txt para descargar contenido restringido de Instagram, etc.
# Exportar con la extensión "Get cookies.txt LOCALLY" desde el navegador
COOKIES_FILE=
